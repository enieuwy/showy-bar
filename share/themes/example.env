# codexbar-bars — built-in example palette theme
#
# Minimal pattern: set the four primary role colors and let secondary/
# tertiary auto-derive from the configured scale knobs.
: "${CB_BARS_PALETTE_PRIMARY_GOOD:=89b4fa}"
: "${CB_BARS_PALETTE_PRIMARY_WARN:=f9e2af}"
: "${CB_BARS_PALETTE_PRIMARY_BAD:=f38ba8}"
: "${CB_BARS_PALETTE_PRIMARY_UNKNOWN:=9399b2}"

# Full pattern example: uncomment role overrides when you want direct control
# instead of scaled primary colors.
# : "${CB_BARS_PALETTE_SECONDARY_GOOD:=4b6389}"
# : "${CB_BARS_PALETTE_SECONDARY_WARN:=887c60}"
