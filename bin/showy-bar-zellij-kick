#!/usr/bin/env bash
# showy-bar — one-shot zjstatus pipe update.
#
# Useful after creating a Zellij tab: new zjstatus plugin instances start with
# empty pipe state and otherwise wait for the long-running feeder's next tick.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/common.sh"

BAR="${SCRIPT_DIR}/showy-bar-zellij-bar"
[[ -x "${BAR}" ]] || showy_bar_die "missing renderer: ${BAR}"
export SHOWY_BAR_FORCE_COLOR=1

showy_bar_have "${SHOWY_BAR_ZELLIJ_BIN}" || showy_bar_die "zellij is required for pipe mode: ${SHOWY_BAR_ZELLIJ_BIN}"

widget="${SHOWY_BAR_ZELLIJ_WIDGET}"
pipe_name="${SHOWY_BAR_ZELLIJ_PIPE_NAME}"
plugin="${SHOWY_BAR_ZELLIJ_PLUGIN}"
pipe_timeout_tenths="${SHOWY_BAR_ZELLIJ_PIPE_TIMEOUT_TENTHS}"
[[ "${pipe_timeout_tenths}" =~ ^[0-9]+$ ]] || pipe_timeout_tenths=20
zellij_args=()
if [[ -n "${ZELLIJ_SESSION_NAME:-}" ]]; then
    zellij_args+=(--session "${ZELLIJ_SESSION_NAME}")
fi


reap_timed_out_pipe() {
    local child="$1" waited=0
    kill "${child}" 2>/dev/null || true
    while kill -0 "${child}" 2>/dev/null; do
        if (( waited >= 5 )); then
            kill -KILL "${child}" 2>/dev/null || true
            break
        fi
        sleep 0.1
        waited=$((waited + 1))
    done
    wait "${child}" >/dev/null 2>&1 || true
}

send_pipe() {
    local payload="$1" child waited=0
    local args=(pipe --name "${pipe_name}")
    if [[ -n "${plugin}" ]]; then
        args+=(--plugin "${plugin}")
    fi
    args+=(-- "${payload}")

    "${SHOWY_BAR_ZELLIJ_BIN}" "${zellij_args[@]}" "${args[@]}" </dev/null >/dev/null 2>&1 &
    child=$!
    while kill -0 "${child}" 2>/dev/null; do
        if (( waited >= pipe_timeout_tenths )); then
            reap_timed_out_pipe "${child}"
            return 1
        fi
        sleep 0.1
        waited=$((waited + 1))
    done
    wait "${child}" >/dev/null 2>&1
}

if output=$("${BAR}" 2>/dev/null) && [[ -n "${output}" ]]; then
    send_pipe "zjstatus::pipe::${widget}::${output}"
fi
